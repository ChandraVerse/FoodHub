# MongoDB Atlas Connection
# Get your connection string from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com/
# 2. Select your cluster
# 3. Click "Connect"
# 4. Choose "Drivers" and select Java
# 5. Copy your connection string
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/foodhub?retryWrites=true&w=majority
